# Auto detect text files and perform LF normalization
* text=auto

# ── Git LFS — büyük veri dosyaları ──────────────────────────────────────────
# public/datas/ — ham kaynak veriler (245MB İETT hat verisi dahil)
public/datas/* filter=lfs diff=lfs merge=lfs -text
# public/data/ — işlenmiş simülasyon verileri
public/data/bus_sim.json filter=lfs diff=lfs merge=lfs -text
# public/gtfs and more/ — GTFS kaynak dosyaları
public/gtfs[[:space:]]and[[:space:]]more/stop_times.csv filter=lfs diff=lfs merge=lfs -text
public/gtfs[[:space:]]and[[:space:]]more/shapes.csv filter=lfs diff=lfs merge=lfs -text
public/gtfs[[:space:]]and[[:space:]]more/trips.csv filter=lfs diff=lfs merge=lfs -text
# pipeline/ — büyük zip dosyaları
pipeline/gtfs_stop_times.zip filter=lfs diff=lfs merge=lfs -text
# Genel — binary büyük dosya formatları
*.pbf filter=lfs diff=lfs merge=lfs -text
*.tar filter=lfs diff=lfs merge=lfs -text
public/data/turkey_overlays/bus_routes.geojson filter=lfs diff=lfs merge=lfs -text
